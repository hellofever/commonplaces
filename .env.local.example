# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JavaScript API key -- public (shipped to the browser), so restrict it by
# HTTP referrer in Google Cloud Console to just this app's domain(s).
# Requires: Maps JavaScript API enabled, plus a Map ID (Cloud Console > Google Maps
# Platform > Map Management) for Advanced Markers to render -- set it below.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Map ID for Advanced Markers (not a secret -- public like the Maps key). Leave empty
# to fall back to the project's default Map ID hardcoded in components/MapView.tsx.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Google Places API (New) key -- server-only, read in app/api/places/*/route.ts.
# Never exposed to the browser, so no HTTP referrer restriction applies; restrict it to
# just the Places API (New) in Cloud Console instead. Set a small budget alert too --
# see CLAUDE.md for the expected cost (should be $0/month at this app's scale).
GOOGLE_PLACES_API_KEY=
